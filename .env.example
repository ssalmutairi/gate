# Database
DATABASE_URL=postgres://gate:gate@localhost:5555/gate

# Proxy
PROXY_PORT=8080

# Admin API
ADMIN_PORT=9000
ADMIN_BIND_ADDR=127.0.0.1
ADMIN_TOKEN=changeme

# Logging
LOG_LEVEL=info

# Config reload
CONFIG_POLL_INTERVAL_SECS=5

# Health checks
HEALTH_CHECK_INTERVAL_SECS=10
HEALTH_CHECK_PATH=/health

# Metrics
METRICS_PORT=9091

# Service import
# MAX_SPEC_SIZE_MB=25

# Redis (optional — enables distributed rate limiting and circuit breaker sync)
# REDIS_URL=redis://localhost:6379
# REDIS_POOL_SIZE=8

# TLS (optional)
# TLS_CERT_PATH=
# TLS_KEY_PATH=
